#!/usr/bin/env sh
set -eu

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
COMPOSE_FILE="$ROOT_DIR/infra/chatwoot-dev/compose.yml"

if ! docker info >/dev/null 2>&1; then
  echo "Docker is not running. Start Docker Desktop, OrbStack, or Colima and try again." >&2
  exit 1
fi

docker compose -f "$COMPOSE_FILE" up -d

cat <<EOF

Chatwoot dev stack is starting.

Open:
  http://localhost:${CHATWOOT_PORT:-3000}

Logs:
  ./scripts/chatwoot-dev-logs

Reset:
  ./scripts/chatwoot-dev-reset

EOF
