#!/usr/bin/env python3
"""Create or update the public-dev Chatwoot webhook for the laptop tunnel."""

from pathlib import Path
import sys


ROOT_DIR = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT_DIR / "infra" / "public-dev-laptop"))

from public_dev_tools import main_for  # noqa: E402


if __name__ == "__main__":
    raise SystemExit(main_for("sync"))
