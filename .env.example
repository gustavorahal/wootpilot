# WootPilot local/default configuration template.
# Copy to .env.local and fill secrets locally. Do not commit real .env files.

ENV=local
LOG_LEVEL=info
WORKFLOW_TRACE=true
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=wootpilot-local
LANGSMITH_ENDPOINT=
PUBLIC_BASE_URL=http://localhost:8000
WEBHOOK_PATH=/webhooks/chatwoot

# Persistence
DB_URL=sqlite+aiosqlite:///./data/wootpilot.db
CHECKPOINTER=sqlite

# Automation behavior
AUTOMATION_MODE=public_reply
RESPONSE_LOCALE=pt-BR
HUMAN_OPERATOR_ACTIVE_TTL_SECONDS=900
OUTBOUND_RETRY_DELAY_SECONDS=60
OUTBOUND_MAX_ATTEMPTS=3

# Local disposable Chatwoot stack
CHATWOOT_BASE_URL=http://localhost:3000
CHATWOOT_PUBLIC_URL=http://localhost:3000
CHATWOOT_ACCOUNT_ID=change-me
CHATWOOT_API_TOKEN=change-me
CHATWOOT_WEBHOOK_SECRET=change-me
CHATWOOT_WEBHOOK_SIGNATURE_MODE=chatwoot-hmac-sha256
CHATWOOT_WEBHOOK_SIGNATURE_HEADER=x-chatwoot-signature
CHATWOOT_WEBHOOK_TIMESTAMP_HEADER=x-chatwoot-timestamp
CHATWOOT_WEBHOOK_DELIVERY_HEADER=x-chatwoot-delivery
CHATWOOT_UPDATE_STATUS_AFTER_PUBLIC_REPLY=false
CHATWOOT_PUBLIC_REPLY_STATUS=pending
CHATWOOT_MARK_NEEDS_HUMAN_ON_PRIVATE_REVIEW=true
CHATWOOT_NEEDS_HUMAN_LABEL=wootpilot-needs-human

# Model provider
MODEL_PROVIDER=openrouter
OPENROUTER_API_KEY=change-me
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Catalog connector
CATALOG_CONNECTOR_MODE=mock
MOCK_CATALOG_PATH=./data/mock-woocommerce/catalog.demo-car-parts.json
WOOCOMMERCE_STORE_API_BASE_URL=
