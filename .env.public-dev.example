# WootPilot public-dev Chatwoot configuration template.
# Copy to .env.local when running WootPilot from your machine against
# https://chat.gmrahal.net. Do not commit filled values.

WOOTPILOT_ENV=public_dev
WOOTPILOT_LOG_LEVEL=info

# Chatwoot must be able to reach this URL for webhooks. If WootPilot runs
# locally, expose it with a tunnel and put the public tunnel URL here.
WOOTPILOT_PUBLIC_BASE_URL=https://<your-wootpilot-public-url>
WOOTPILOT_WEBHOOK_PATH=/webhooks/chatwoot

# Local WootPilot persistence while testing against the public dev Chatwoot.
WOOTPILOT_DB_URL=sqlite+aiosqlite:///./data/wootpilot-public-dev.db
WOOTPILOT_CHECKPOINTER=sqlite
WOOTPILOT_LIMITED_AUTO_PRODUCTION_ALLOWED=false

# Keep writes conservative when validating live integration.
WOOTPILOT_BOT_MODE=shadow
WOOTPILOT_HUMAN_OPERATOR_ACTIVE_TTL_SECONDS=1800

# Public dev Chatwoot.
WOOTPILOT_CHATWOOT_BASE_URL=https://chat.gmrahal.net
WOOTPILOT_CHATWOOT_PUBLIC_URL=https://chat.gmrahal.net
WOOTPILOT_CHATWOOT_ACCOUNT_ID=change-me
WOOTPILOT_CHATWOOT_API_TOKEN=change-me
WOOTPILOT_CHATWOOT_WEBHOOK_SECRET=change-me
WOOTPILOT_CHATWOOT_WEBHOOK_SIGNATURE_MODE=chatwoot-hmac-sha256
WOOTPILOT_CHATWOOT_WEBHOOK_SIGNATURE_HEADER=x-chatwoot-signature
WOOTPILOT_CHATWOOT_WEBHOOK_TIMESTAMP_HEADER=x-chatwoot-timestamp
WOOTPILOT_CHATWOOT_WEBHOOK_DELIVERY_HEADER=x-chatwoot-delivery

# Model provider
WOOTPILOT_MODEL_PROVIDER=openrouter
WOOTPILOT_OPENROUTER_API_KEY=change-me
WOOTPILOT_OPENROUTER_MODEL=openai/gpt-4o-mini

# Catalog connector
WOOTPILOT_CATALOG_CONNECTOR_MODE=mock
WOOTPILOT_MOCK_CATALOG_PATH=./data/mock-woocommerce/catalog.demo-car-parts.json
WOOTPILOT_WOOCOMMERCE_STORE_API_BASE_URL=
